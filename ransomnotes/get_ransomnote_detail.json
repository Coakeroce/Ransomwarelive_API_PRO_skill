{
  "skill_id": "ransomnotes_get_ransomnote_detail",
  "name": "get_ransomnote_detail",
  "display_name": "获取勒索信完整内容",
  "description": "根据组织名和文件名返回特定勒索信的完整文本内容（支持 .txt、.html 或 .md 格式）。",
  "category": "ransomnotes",
  "version": "1.0.0",
  "api": {
    "base_url": "https://api-pro.ransomware.live",
    "endpoint": "/ransomnotes/{group}/{note_name}",
    "method": "GET",
    "content_type": "application/json",
    "auth": {
      "type": "apikey",
      "in": "header",
      "name": "X-API-KEY"
    }
  },
  "parameters_map": {
    "group":     { "in": "path", "required": true },
    "note_name": { "in": "path", "required": true }
  },
  "function": {
    "type": "function",
    "function": {
      "name": "get_ransomnote_detail",
      "description": "根据组织名和文件名返回勒索信的完整内容（支持 .txt、.html 或 .md 格式）。",
      "parameters": {
        "type": "object",
        "properties": {
          "group": {
            "type": "string",
            "description": "勒索软件组织名称"
          },
          "note_name": {
            "type": "string",
            "description": "勒索信文件名，含扩展名（例如：README.txt、ransom_note.html）"
          }
        },
        "required": ["group", "note_name"]
      }
    }
  },
  "examples": [
    {
      "description": "获取 LockBit 组织 README.txt 勒索信内容",
      "input": { "group": "lockbit", "note_name": "README.txt" }
    }
  ]
}
